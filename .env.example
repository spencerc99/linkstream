# URL of the deployed workers/haiku Cloudflare Worker.
# Enables the "Haiku" mode on the /HAH/poster experiment.
# Leave unset to keep Haiku mode disabled.
VITE_HAIKU_WORKER_URL=https://linkstream-haiku.yoursubdomain.workers.dev

# Shared secret sent as the x-haiku-key header to the Haiku worker. Must match
# the worker's CLIENT_SECRET (set via: bunx wrangler secret put CLIENT_SECRET).
# Keep this out of public/prod builds so the worker can't be called by others.
VITE_HAIKU_KEY=

# Canonical origin the app is served from in production. Baked into
# dist/client-metadata.json at build so AT Proto OAuth client_id/redirect_uris
# match the serving origin exactly. On Cloudflare Pages this falls back to the
# auto-provided CF_PAGES_URL (*.pages.dev) when unset, so you only need to set
# this once a custom domain is attached. No trailing slash.
VITE_OAUTH_ORIGIN=https://hah.spencer.place
